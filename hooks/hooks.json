{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}\"/scripts/enforce-agent-model.py",
            "statusMessage": "quartermaster: enforcing cost-tier model pins"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"${CLAUDE_CODE_SUBAGENT_MODEL:-}\" ]; then printf '{\"systemMessage\":\"⚠️ quartermaster: CLAUDE_CODE_SUBAGENT_MODEL=%s is set — it silently overrides ALL agent model pins\"}' \"$CLAUDE_CODE_SUBAGENT_MODEL\"; fi"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}\"/scripts/classify-mcp.py --templates \"${CLAUDE_PLUGIN_ROOT}\"/templates",
            "async": true,
            "statusMessage": "quartermaster: syncing MCP tool tiers"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && jq -c '. + {ts: (now | todate)}' >> ~/.claude/logs/subagents.jsonl",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && jq -c '. + {ts: (now | todate)}' >> ~/.claude/logs/subagent-stops.jsonl",
            "async": true
          }
        ]
      }
    ]
  }
}
