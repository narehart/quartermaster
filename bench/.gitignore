# Heavy per-run outputs (Docker eval dirs, patches, transcripts) — regenerable
jobs_*/
results/**/eval/
work/
# Local venv + caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
# Run logs and HuggingFace dataset cache
*.log
.dataset_cache/
hf_cache/
