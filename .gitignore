*.quartermaster-bak-*
.quartermaster-legacy-backup-*
# legacy backup names from the tokenwise -> quartermaster rename (install.sh
# may still encounter these on a machine that never re-ran the installer)
*.tokenwise-bak-*
.tokenwise-legacy-backup-*

# python dev tooling
.venv/
.coverage
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
uv.lock

# defensive: never track local secrets/env files
.env
.env.*

# subagent worktrees (transient, may contain embedded git repos)
.claude/worktrees/
